node_modules/
.DS_Store
__pycache__/

# Generic Rust target/ at the repo root + any nested in workspace-member
# crates under crates/. Path deps like sacred-error generate their own
# when built standalone (e.g. `cd crates/sacred-error && cargo test`).
/target
crates/*/target/

# Build artefacts inside each subproject — the subproject's own
# .gitignore could also carry these, but listing them here keeps a
# single source of truth for "things we never commit."
ccg/dist/
ccg/target/
ccg/.em-cache/
ccg/assets/src/elm-stuff/
ccg/assets/elm-stuff/
ccg/frontend-garden/debug.log
ccg/frontend-garden/target/
ccg/tsot-report.html

# TSOT EA artifacts — generated by `tsot evolve` and `tsot champions-report`
ccg/champions/
ccg/champion.json
ccg/champion-*.json
ccg/evolved-*.json
ccg/champions-report.html
ccg/champions-grid.html
ccg/matchup-evolved.html
ccg/matchup-*.html
ccg/evolve-report.html
ccg/card-pool.html
ccg/prune-report.html
ccg/balance-probe-*.json
ccg/balance-probe-report.html
ccg/archetypes-report.html
ccg/card-curve.json

# `make art` output — generated card art (one png per card)
ccg/gen_art/

# Image assets used by gen_art (third-party icons, etc.)
ccg/assets/icons/
